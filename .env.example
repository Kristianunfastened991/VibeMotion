# Copy this file to .env for local development. Do not commit .env.

# Optional Figma REST token. The app also supports the local Figma bridge without REST.
FIGMA_ACCESS_TOKEN=

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
VISION_FRAME_COUNT=8

# Optional setup/runtime flags for advanced users.
# Default first launch installs/checks Ollama and downloads the configured models.
VIBEMOTION_SKIP_OLLAMA_PULL=

# Transcription
WHISPER_MODEL=turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=float16
WHISPER_CPU_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_BATCH_SIZE=16
TRANSCRIPT_LANGUAGE=

# Rendering
FFMPEG_ENCODER=auto
FFMPEG_CPU_ENCODER=libx264

# Optional gated model downloads.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
HUGGINGFACE_TOKEN=
VIBEMOTION_USE_GATED_GEMMA=
